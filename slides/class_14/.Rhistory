library(shiny)
library(ggplot2)
# Define UI for the app
ui <- fluidPage(
titlePanel("Confidence Intervals for Sample Means"),
sidebarLayout(
sidebarPanel(
actionButton("sampleButton", "Draw New Sample")
),
mainPanel(
plotOutput("ciPlot")
)
)
)
# Define server logic
server <- function(input, output) {
observeEvent(input$sampleButton, {
output$ciPlot <- renderPlot({
set.seed(NULL) # Initialize random seed
true_mean <- 50
sd <- 10
sample_size <- 100
sample <- rnorm(sample_size, true_mean, sd)
sample_mean <- mean(sample)
stderr <- sd / sqrt(sample_size)
ci_low <- sample_mean - 1.96 * stderr
ci_high <- sample_mean + 1.96 * stderr
ggplot(data.frame(x = c(1, 2), y = c(true_mean, sample_mean),
ymin = c(true_mean, ci_low), ymax = c(true_mean, ci_high)),
aes(x = x, y = y, ymin = ymin, ymax = ymax)) +
geom_pointrange(aes(color = factor(x))) +
scale_color_manual(values = c("#001F3F", "#800000")) +
labs(title = "Confidence Interval for Sample Mean",
x = NULL,
y = expression(mu),
color = "Legend") +
theme_minimal() +
geom_hline(yintercept = true_mean, color = "#225522", size = 1, linetype = "dashed") +
annotate("text", x = 1.5, y = true_mean + 5, label = expression(paste("True ", mu)), hjust = 0.5) +
scale_x_continuous(breaks = c(1, 2), labels = c("True Mean", "Sample Mean & CI")) +
theme(legend.position = "none")
})
})
}
# Run the app
shinyApp(ui, server)
library(shiny)
library(ggplot2)
# Define UI for the app
ui <- fluidPage(
titlePanel("Confidence Intervals for Sample Means"),
sidebarLayout(
sidebarPanel(
actionButton("sampleButton", "Draw New Sample")
),
mainPanel(
plotOutput("ciPlot")
)
)
)
# Define server logic
server <- function(input, output) {
samples_data <- reactiveVal(data.frame(x = numeric(0), y = numeric(0),
ymin = numeric(0), ymax = numeric(0)))
observeEvent(input$sampleButton, {
true_mean <- 50
sd <- 10
sample_size <- 100
sample <- rnorm(sample_size, true_mean, sd)
sample_mean <- mean(sample)
stderr <- sd / sqrt(sample_size)
ci_low <- sample_mean - 1.96 * stderr
ci_high <- sample_mean + 1.96 * stderr
new_data <- data.frame(x = max(nrow(samples_data()), 1),
y = sample_mean, ymin = ci_low, ymax = ci_high)
# Append new data to the existing data
samples_data(rbind(samples_data(), new_data))
output$ciPlot <- renderPlot({
ggplot(samples_data(), aes(x = x, y = y, ymin = ymin, ymax = ymax)) +
geom_pointrange(aes(color = "#800000")) +
labs(title = "Confidence Intervals for Sample Means",
x = "Sample Draw",
y = expression(mu)) +
theme_minimal() +
geom_hline(yintercept = true_mean, color = "#225522", size = 1, linetype = "dashed") +
annotate("text", x = 0.5, y = true_mean + 5, label = expression(paste("True ", mu))) +
theme(legend.position = "none")
})
})
}
# Run the app
shinyApp(ui, server)
library(shiny)
library(ggplot2)
# Define UI for the app
ui <- fluidPage(
titlePanel("Intervalos de Confianza para Medias de Muestra"),
sidebarLayout(
sidebarPanel(
actionButton("sampleButton", "Generar Nueva Muestra"),
br(),
h5("Descripción:"),
p("Haz clic en 'Generar Nueva Muestra' para observar cómo cambian los intervalos de confianza para la media de una muestra. Cada nuevo intervalo se agregará a la gráfica.")
),
mainPanel(
plotOutput("ciPlot")
)
)
)
# Define server logic
server <- function(input, output) {
samples_data <- reactiveVal(data.frame(x = numeric(0), y = numeric(0),
ymin = numeric(0), ymax = numeric(0)))
observeEvent(input$sampleButton, {
media_verdadera <- 50
sd <- 10
tamano_muestra <- 100
muestra <- rnorm(tamano_muestra, media_verdadera, sd)
media_muestra <- mean(muestra)
error_estandar <- sd / sqrt(tamano_muestra)
ci_bajo <- media_muestra - 1.96 * error_estandar
ci_alto <- media_muestra + 1.96 * error_estandar
new_data <- data.frame(x = max(nrow(samples_data()), 1),
y = media_muestra, ymin = ci_bajo, ymax = ci_alto)
# Agregar nuevos datos a los datos existentes
samples_data(rbind(samples_data(), new_data))
output$ciPlot <- renderPlot({
ggplot(samples_data(), aes(x = x, y = y, ymin = ymin, ymax = ymax)) +
geom_pointrange(aes(color = "#800000")) +
labs(title = "Intervalos de Confianza para Medias de Muestra",
x = "Generación de Muestra",
y = expression(mu)) +
theme_minimal() +
geom_hline(yintercept = media_verdadera, color = "#225522", size = 1, linetype = "dashed") +
annotate("text", x = 0.5, y = media_verdadera + 5, label = expression(paste("Media Verdadera ", mu))) +
theme(legend.position = "none")
})
})
}
# Run the app
shinyApp(ui, server)
